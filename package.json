{
  "name": "web-app-edilmaestro",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "preview:private": "vite preview --host 127.0.0.1 --port 4173",
    "android:copy": "npm run build && npx cap copy android",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android",
    "ios:copy": "npm run build && npx cap copy ios",
    "ios:sync": "npm run build && npx cap sync ios",
    "ios:open": "npx cap open ios",
    "android:apk:debug": "npm run android:sync && cd android && gradlew.bat assembleDebug",
    "android:apk:release": "npm run android:sync && cd android && gradlew.bat assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/share": "^8.0.1",
    "jspdf": "^4.2.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.5.1"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.8.3",
    "vite": "^7.1.7",
    "vite-plugin-pwa": "^1.1.0"
  }
}
